# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Multi-Cloud Federation Platform"

# Security
SECRET_KEY=multicloudfederationsecret123
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Identity Settings
CENTRAL_IDP_URL=https://auth.federation.local
TRUSTED_ISSUERS=https://sts.amazonaws.com,https://login.microsoftonline.com,https://accounts.google.com

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=federation_hub

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Federation Parameters
FEDERATION_DOMAIN=federation.local
TOKEN_VALIDATION_CLOCK_SKEW=300
DEFAULT_SESSION_TIMEOUT=3600

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
